{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prd-creator-input.schema.json",
  "title": "Retail PRD Creator — Input",
  "type": "object",
  "required": ["mode", "one_pager_path", "initiative_slug"],
  "properties": {
    "mode": { "enum": ["create", "update"] },
    "initiative_slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "one_pager_path": { "type": "string" },
    "one_pager_review_path": { "type": "string", "description": "Optional: if the one-pager has been reviewed, pass the review report" },
    "prior_prd_path": { "type": "string", "description": "Required for mode=update" },
    "updated_one_pager_path": { "type": "string", "description": "Required for mode=update if one-pager changed" },
    "update_reason": { "type": "string" },

    "personas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "channels", "frequency"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "channels": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "key_actions": { "type": "array", "items": { "type": "string" } },
          "frequency": { "type": "string" },
          "current_pain": { "type": "string" },
          "tech_comfort": { "enum": ["low", "medium", "high"] },
          "accessibility_considerations": { "type": "array", "items": { "type": "string" } },
          "type": { "enum": ["customer", "associate", "internal", "partner"] }
        }
      }
    },

    "journeys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "persona"],
        "properties": {
          "capability": { "type": "string" },
          "persona": { "type": "string" },
          "preconditions": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "actor_action": { "type": "string" },
                "system_response": { "type": "string" },
                "channel": { "type": "string" },
                "notes": { "type": "string" }
              }
            }
          },
          "success_state": { "type": "string" },
          "error_path": { "type": "string" },
          "empty_state": { "type": "string" },
          "abandonment_points": { "type": "array", "items": { "type": "string" } },
          "handoff_points": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority"],
        "properties": {
          "name": { "type": "string" },
          "customer_facing": { "type": "boolean" },
          "channels": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "priority": { "enum": ["P0", "P1", "P2"] }
        }
      }
    },

    "business_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "source", "impact_if_broken"],
        "properties": {
          "id": { "type": "string", "pattern": "^BR-[0-9]{2,}$" },
          "description": { "type": "string" },
          "source": { "type": "string" },
          "impact_if_broken": { "type": "string" },
          "category": { "enum": ["loyalty", "tax", "pricing-promo", "fulfillment", "returns", "inventory", "payments", "customer-data", "compliance", "other"] }
        }
      }
    },

    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "given", "when", "then", "test_type"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]{3,}$" },
          "title": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "given": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "when": { "type": "string" },
          "then": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "test_type": { "enum": ["unit", "integration", "contract", "e2e", "manual", "accessibility", "performance", "security"] },
          "channels": { "type": "array", "items": { "type": "string" } },
          "personas": { "type": "array", "items": { "type": "string" } },
          "maps_to_goal": { "type": "string" },
          "maps_to_br": { "type": "string" },
          "test_data_requirements": { "type": "string" },
          "acceptance_notes": { "type": "string" }
        }
      }
    },

    "nfrs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "requirement", "target", "measured_by"],
        "properties": {
          "id": { "type": "string" },
          "category": { "enum": ["performance", "availability", "security", "pci", "privacy", "accessibility", "scalability", "localization", "observability", "rollback", "compliance"] },
          "requirement": { "type": "string" },
          "target": { "type": "string" },
          "measured_by": { "type": "string" }
        }
      }
    },

    "rollout_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "window", "audience", "feature_flag", "guardrails", "rollback_trigger"],
        "properties": {
          "phase": { "enum": ["internal-dogfood", "closed-beta", "ramp", "ga", "hypercare"] },
          "window": { "type": "string" },
          "audience": { "type": "string" },
          "feature_flag": { "type": "string" },
          "guardrails": { "type": "array", "items": { "type": "string" } },
          "rollback_trigger": { "type": "string" }
        }
      }
    }
  }
}
